CYBERARK_PVWA_URL=https://my.pvwa.com
CYBERARK_AUTH_TYPE=CyberArk
CYBERARK_USERNAME=admin
CYBERARK_PASSWORD=your_password_here
CYBERARK_VERIFY_SSL=true

# OAuth 2.1 (optional — set OAUTH_ENABLED=true to activate)
OAUTH_ENABLED=false
OAUTH_ISSUER=https://your-mcp-server.example.com
OAUTH_CLIENT_ID=mcp-client
OAUTH_CLIENT_SECRET=change-me-to-a-strong-secret
OAUTH_TOKEN_EXPIRY=3600
# OAUTH_PRIVATE_KEY_PEM=  # Leave blank to auto-generate on startup
