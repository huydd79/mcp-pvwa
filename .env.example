CYBERARK_PVWA_URL=https://my.pvwa.com
CYBERARK_AUTH_TYPE=CyberArk
CYBERARK_USERNAME=admin
CYBERARK_PASSWORD=your_password_here
CYBERARK_VERIFY_SSL=true

# OAuth 2.1 (set OAUTH_ENABLED=true to activate)
OAUTH_ENABLED=false
OAUTH_ISSUER=https://your-mcp-server.example.com
OAUTH_CLIENT_ID=mcp-client
OAUTH_CLIENT_SECRET=change-me-to-a-strong-secret
OAUTH_TOKEN_EXPIRY=3600
# OAUTH_PRIVATE_KEY_PEM=  # Leave blank to auto-generate on startup

# External IdP — Okta or CyberArk Identity (overrides built-in OAuth when set)
# IDP_ISSUER=https://your-tenant.id.cyberark.cloud
# IDP_ISSUER=https://your-tenant.okta.com/oauth2/default
# IDP_DISCOVERY_URL=  # Optional: override auto-discovery URL
# IDP_CLIENT_ID=your-idp-app-client-id
# IDP_CLIENT_SECRET=your-idp-app-client-secret
# IDP_AUDIENCE=  # Expected JWT audience (optional)
# IDP_SCOPE=openid profile
