# ==============================================================================
# CyberArk PVWA MCP Server — Environment Variables
# Copy this file to .env and fill in real values before running.
# ==============================================================================

# ------------------------------------------------------------------------------
# PVWA Connection
# ------------------------------------------------------------------------------

# Base URL of the PVWA instance (no trailing slash).
# IMPORTANT: when using SAML authentication, this must match the domain configured
# in the IdP's SAML app ACS URL (use FQDN, not IP address).
CYBERARK_PVWA_URL=https://my.pvwa.com

# Default authentication method for direct PVWA login (not SAML).
# Allowed values: CyberArk | LDAP | Windows | RADIUS  (default: CyberArk)
# Optional — can be overridden per call via the cyberark_logon tool.
# CYBERARK_AUTH_TYPE=CyberArk

# Pre-configured PVWA credentials for direct login (optional).
# If left unset, the MCP client will be prompted to supply username, password,
# and auth_type at runtime via the cyberark_logon tool.
# CYBERARK_USERNAME=
# CYBERARK_PASSWORD=

# Set to false to skip SSL certificate verification (lab environments only)
CYBERARK_VERIFY_SSL=true

# ------------------------------------------------------------------------------
# PVWA SAML Authentication
# When enabled, the server attempts to authenticate to PVWA via SAML first,
# exchanging the caller's OAuth Bearer token for a SAML assertion (RFC 8693).
# Falls back to CYBERARK_USERNAME/PASSWORD if SAML is unavailable or fails.
# Requires IDP_ISSUER to be configured.
# ------------------------------------------------------------------------------

# Enable SAML-first authentication into PVWA
PVWA_SAML_ENABLED=false

# Direct IdP SSO URL for the PVWA SAML app (recommended — skips all discovery).
# For CyberArk Identity: copy the SingleSignOnService Location from the IdP metadata XML.
#   Example: https://<tenant>.my.idaptive.app/applogin/appKey/<app-key>/customerId/<customer-id>
# When set, PVWA_SAML_APP_KEY is not required.
# PVWA_SAML_SSO_URL=

# App key / UUID of the PVWA SAML app at the IdP.
# Only needed when PVWA_SAML_SSO_URL is NOT set — used to auto-generate candidate SSO URLs.
# For CyberArk Identity: found in the SAML app settings or the IdP metadata entityID.
# PVWA_SAML_APP_KEY=

# ------------------------------------------------------------------------------
# OAuth 2.1 — MCP Server Authentication
# Protects the /mcp endpoint with Bearer token validation.
# When OAUTH_ENABLED=false, any client can call /mcp without authentication.
# ------------------------------------------------------------------------------

# Enable OAuth token enforcement on /mcp
OAUTH_ENABLED=false

# Public URL of this MCP server — used as the JWT issuer and base URL for proxy endpoints.
# Must be reachable by MCP clients from outside.
OAUTH_ISSUER=https://your-mcp-server.example.com

# Static client credentials (used for internal OAuth when IDP_ISSUER is not set)
OAUTH_CLIENT_ID=mcp-client
OAUTH_CLIENT_SECRET=change-me-to-a-strong-secret

# Access token lifetime in seconds
OAUTH_TOKEN_EXPIRY=3600

# RSA private key in PEM format for signing JWTs.
# Leave blank to auto-generate on every startup.
# Set a fixed value when running multiple replicas or when tokens must survive a restart.
# OAUTH_PRIVATE_KEY_PEM=

# ------------------------------------------------------------------------------
# External IdP — CyberArk Identity / Okta / Azure AD
# When IDP_ISSUER is set, this server acts as an OAuth proxy:
#   /oauth/authorize  → redirects to the IdP
#   /oauth/token      → proxies to the IdP token endpoint
#   POST /mcp         → validates tokens using the IdP's JWKS
# Internal OAuth (OAUTH_CLIENT_ID/SECRET) is ignored when an external IdP is used.
# ------------------------------------------------------------------------------

# IdP issuer URL (uncomment the relevant line)
# IDP_ISSUER=https://your-tenant.id.cyberark.cloud          # CyberArk Identity
# IDP_ISSUER=https://your-tenant.okta.com/oauth2/default    # Okta
# IDP_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0 # Azure AD

# Override the OIDC discovery URL if the IdP does not use the standard well-known path
# IDP_DISCOVERY_URL=

# OAuth app credentials registered in the IdP
# IDP_CLIENT_ID=your-idp-app-client-id
# IDP_CLIENT_SECRET=your-idp-app-client-secret

# Expected JWT audience claim (leave blank if the IdP does not set one)
# IDP_AUDIENCE=

# Scopes to request when redirecting to the IdP.
# Must match the scopes configured in the IdP application:
#   CyberArk Identity : openid profile email
#   Okta              : openid profile email offline_access
#   Azure AD          : openid profile email offline_access
# IDP_SCOPE=openid profile email
